{
  "name": "Real Estate Streamlit (Python)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": ["app.py"]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter"
      ]
    }
  },
  "updateContentCommand": "if [ -f packages.txt ]; then sudo apt-get update && sudo xargs -a packages.txt apt-get install -y; fi && if [ -f requirements.txt ]; then pip3 install --user -r requirements.txt; fi && echo 'Environment ready'",
  "postAttachCommand": {
    "server": "streamlit run app.py --server.address 0.0.0.0 --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}